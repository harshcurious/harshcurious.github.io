&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;&amp;gt;&amp;gt;&amp;gt;&lt;/span&gt; new&lt;span style="color:#f92672"&gt;.&lt;/span&gt;loc[&lt;span style="color:#e6db74"&gt;&amp;#39;x&amp;#39;&lt;/span&gt;]
